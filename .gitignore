# Python
__pycache__/
*.pyc
*.pyo

# Retratos grandes (8+ MB, so usados por scripts/vision.py legado)
cache/portraits/
# cache/icons/ E versionado: o overlay usa (1 MB) e o build do instalador empacota

# Temporarios
*.log

# Chave da OpenAI (voz) - server-only, nunca versionar
openai_secret.json

# Historico de relatorios por partida (gerado em tempo de jogo)
match_history/

# Gerados em execucao (prints de captura, configs por maquina)
runtime/
overlay_config.json

# Build do instalador (gerados pelo scripts/build_installer.ps1 / CI)
build/
dist/
copiloto/_version.py

# Chaves de API dos provedores de IA (secreto)
ai_config.json
runtime/hotkeys.json
